{
  "tables": [
    {
      "name": "users",
      "columns": [
        { "name": "id",         "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
        { "name": "username",   "type": "TEXT",    "constraints": ["UNIQUE", "NOT NULL"] },
        { "name": "created_at", "type": "TEXT",    "constraints": ["NOT NULL", "DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))"] }
      ],
      "indices": [
        { "name": "idx_users_username", "columns": ["username"], "unique": true }
      ]
    },
    {
      "name": "boards",
      "columns": [
        { "name": "id",      "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
        { "name": "user_id", "type": "INTEGER", "constraints": ["NOT NULL", "REFERENCES users(id) ON DELETE CASCADE"] },
        { "name": "title",   "type": "TEXT",    "constraints": ["NOT NULL"] }
      ],
      "indices": [
        { "name": "idx_boards_user_id", "columns": ["user_id"], "unique": false }
      ]
    },
    {
      "name": "columns",
      "columns": [
        { "name": "id",       "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
        { "name": "board_id", "type": "INTEGER", "constraints": ["NOT NULL", "REFERENCES boards(id) ON DELETE CASCADE"] },
        { "name": "title",    "type": "TEXT",    "constraints": ["NOT NULL"] },
        { "name": "position", "type": "INTEGER", "constraints": ["NOT NULL"] }
      ],
      "indices": [
        { "name": "idx_columns_board_id", "columns": ["board_id"], "unique": false }
      ]
    },
    {
      "name": "cards",
      "columns": [
        { "name": "id",        "type": "INTEGER", "constraints": ["PRIMARY KEY"] },
        { "name": "column_id", "type": "INTEGER", "constraints": ["NOT NULL", "REFERENCES columns(id) ON DELETE CASCADE"] },
        { "name": "title",     "type": "TEXT",    "constraints": ["NOT NULL"] },
        { "name": "details",   "type": "TEXT",    "constraints": ["NOT NULL", "DEFAULT ''"] },
        { "name": "position",  "type": "INTEGER", "constraints": ["NOT NULL"] }
      ],
      "indices": [
        { "name": "idx_cards_column_id", "columns": ["column_id"], "unique": false }
      ]
    }
  ]
}
