frontend/next-env.d.ts

# ── Backend (Python / uv) ─────────────────────────────────────────────────────
backend/.venv/
backend/__pycache__/
backend/app/__pycache__/
backend/tests/__pycache__/
backend/*.pyc
backend/.coverage
backend/.pytest_cache/
