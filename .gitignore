# macOS
.DS_Store

# Secrets — never commit
.env

# ── Frontend (Next.js / Node) ─────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
